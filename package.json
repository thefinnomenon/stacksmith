{
  "name": "stacksmith",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Forge full-stack apps from blueprint to production.",
  "bin": {
    "stacksmith": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./schema": "./dist/db/schema.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "dev": "tsx src/cli.ts"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22"
  }
}
